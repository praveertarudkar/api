# API Nest by Praveer Tarudkar
# Environment Configuration
# Copy this to .env and adjust values

# Server
PORT=3000

# Database (SQLite default — no config needed)
# DB_PATH=./data/apinest.db

# JWT Secret — CHANGE THIS IN PRODUCTION!
JWT_SECRET=apinest_jwt_secret_change_in_production_please

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Optional: MongoDB (if using MongoDB adapter)
# MONGODB_URI=mongodb://localhost:27017/apinest

# Optional: PostgreSQL (if using PostgreSQL adapter)
# POSTGRES_URI=postgresql://user:password@localhost:5432/apinest
